# ── AuthorChain environment ───────────────────────────────────────────────
# Copy to .env.local and fill in. Everything is optional in Phase 1; the app
# falls back to mock behavior when a key is missing.

# Database (Phase 2 — Prisma + PostgreSQL)
# Matches docker-compose.yml (host port 5433 to avoid clashing with other local
# Postgres). Run `docker compose up -d` then `npm run db:migrate`.
DATABASE_URL="postgresql://authorchain:authorchain@localhost:5433/authorchain?schema=public"

# Auth — Privy (account abstraction: email/social login + embedded wallets)
# Create an app at https://dashboard.privy.io and paste the App ID + secret.
# Required to use the author dashboard and reader library. When unset, auth
# features are unavailable but the app still builds and public pages still load.
NEXT_PUBLIC_PRIVY_APP_ID=""
PRIVY_APP_SECRET=""
# Optional: paste the app's verification key to verify tokens without a network
# fetch (from the Privy dashboard). Leave blank to fetch it automatically.
PRIVY_VERIFICATION_KEY=""
# Comma-separated Privy user IDs (did:privy:...) granted admin (future use).
ADMIN_PRIVY_IDS=""
# Legacy — no longer used by auth (Privy manages sessions). Kept for reference.
AUTH_SECRET=""

# AI agents (Phase 5) — when set, agents use Claude instead of mock output
ANTHROPIC_API_KEY=""

# Storage (Phase 1+) — local | ipfs | arweave | s3
STORAGE_DRIVER="local"

# Payments — Stripe (Phase 6)
# Public base URL used to build Stripe success/cancel redirect URLs.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
STRIPE_SECRET_KEY=""
# From `stripe listen` (whsec_...). Required to verify webhook signatures.
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Payments — USDC on Base (Phase 6)
AUTHORCHAIN_PAYOUT_ADDRESS=""

# Blockchain — proof of authorship on Base Sepolia testnet
NEXT_PUBLIC_CHAIN_NETWORK="base-sepolia"
NEXT_PUBLIC_BASE_SEPOLIA_CHAIN_ID="84532"
# Deployed AuthorChainRegistry address (from `npm run hh:deploy`).
NEXT_PUBLIC_REGISTRY_ADDRESS=""
BASE_SEPOLIA_RPC_URL="https://sepolia.base.org"
# Server signer used to register proofs on-chain (keep secret, TESTNET ONLY —
# never a funded mainnet key). Also used by Hardhat deploy.
DEPLOYER_PRIVATE_KEY=""
