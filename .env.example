# ── AuthorChain environment ───────────────────────────────────────────────
# Copy to .env.local and fill in. Everything is optional in Phase 1; the app
# falls back to mock behavior when a key is missing.

# Database (Phase 2 — Prisma + PostgreSQL)
# Matches docker-compose.yml (host port 5433 to avoid clashing with other local
# Postgres). Run `docker compose up -d` then `npm run db:migrate`.
#
# SAFETY: keep exactly ONE active DATABASE_URL (and one DIRECT_URL) line, and
# locally it MUST be your LOCAL/dev database — never production. A duplicate
# DATABASE_URL is a footgun: the LAST active line wins, so an uncommented Neon
# (production) URL silently makes every local Prisma command hit production.
# Production DATABASE_URL / DIRECT_URL live in Vercel only — do NOT paste real
# Neon URLs here, and comment out any production line in your local .env.
DATABASE_URL="postgresql://authorchain:authorchain@localhost:5433/authorchain?schema=public"
# Direct (non-pooled) connection used only by Prisma migrations. On hosted
# serverless Postgres (Neon), DATABASE_URL is the POOLED url and DIRECT_URL is
# the direct one. Locally, set DIRECT_URL to the same value as DATABASE_URL.
DIRECT_URL="postgresql://authorchain:authorchain@localhost:5433/authorchain?schema=public"
# Production (set in Vercel only — never active in local .env):
# DATABASE_URL="set-in-vercel-only"   # Neon pooled URL
# DIRECT_URL="set-in-vercel-only"     # Neon direct URL

# Auth — Privy (account abstraction: email/social login + embedded wallets)
# Create an app at https://dashboard.privy.io and paste the App ID + secret.
# Required to use the author dashboard and reader library. When unset, auth
# features are unavailable but the app still builds and public pages still load.
NEXT_PUBLIC_PRIVY_APP_ID=""
PRIVY_APP_SECRET=""
# Optional: paste the app's verification key to verify tokens without a network
# fetch (from the Privy dashboard). Leave blank to fetch it automatically.
PRIVY_VERIFICATION_KEY=""
# Comma-separated Privy user IDs (did:privy:...) granted admin (future use).
ADMIN_PRIVY_IDS=""
# Legacy — no longer used by auth (Privy manages sessions). Kept for reference.
AUTH_SECRET=""

# AI agents (Phase 5) — when set, agents use Claude instead of mock output
ANTHROPIC_API_KEY=""

# Storage (Phase 1+) — local | r2 | ipfs | arweave | s3
STORAGE_DRIVER="local"
# Cloudflare R2 (used when STORAGE_DRIVER=r2). S3-compatible; create an R2
# bucket + an S3 API token in the Cloudflare dashboard. Never commit real values.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
# Optional: override the derived endpoint (https://<account>.r2.cloudflarestorage.com)
R2_ENDPOINT=""

# Public site contact + social (footer / contact page / JSON-LD). Optional —
# the app already ships with these public defaults; set env to override.
# NEXT_PUBLIC_CONTACT_EMAIL="rigovivas71@gmail.com"
# NEXT_PUBLIC_CONTACT_FORM_URL=""
# NEXT_PUBLIC_SOCIAL_GITHUB="https://github.com/rigocrypto/AuthorChain"
# NEXT_PUBLIC_SOCIAL_X="https://x.com/rigo_crypto"
# NEXT_PUBLIC_SOCIAL_LINKEDIN="https://www.linkedin.com/in/rigo-crypto-491204366"
# Discord: full invite/profile URL, or just a username (shown as text if not a URL)
# NEXT_PUBLIC_SOCIAL_DISCORD="https://discord.com/quest-home"
# NEXT_PUBLIC_SOCIAL_YOUTUBE="https://www.youtube.com/@rigocrypto"

# Payments — Stripe (Phase 6)
# Public base URL used to build Stripe success/cancel redirect URLs.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
STRIPE_SECRET_KEY=""
# From `stripe listen` (whsec_...). Required to verify webhook signatures.
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Payments — USDC on Base (Phase 6)
AUTHORCHAIN_PAYOUT_ADDRESS=""

# Blockchain — proof of authorship on Base Sepolia testnet
NEXT_PUBLIC_CHAIN_NETWORK="base-sepolia"
NEXT_PUBLIC_BASE_SEPOLIA_CHAIN_ID="84532"
# Deployed AuthorChainRegistry address (from `npm run hh:deploy`).
NEXT_PUBLIC_REGISTRY_ADDRESS=""
BASE_SEPOLIA_RPC_URL="https://sepolia.base.org"
# Server signer used to register proofs on-chain (keep secret, TESTNET ONLY —
# never a funded mainnet key). Also used by Hardhat deploy.
DEPLOYER_PRIVATE_KEY=""

# ── Upload malware scanning (Security phase S2) ──────────────────────────────
# Uploaded files are scanned at finalize. Fail-closed: if no provider is set,
# NEW uploads are rejected in production (existing files are unaffected).
#   - unset            → production fails closed; local dev falls back to a
#                        clearly-labeled MOCK scanner (never runs in production).
#   - "mock"           → dev-only mock (CLEAN, or INFECTED for an EICAR test file).
#   - "clamav-http"    → POST bytes to a self-hosted/dedicated ClamAV HTTP service
#                        that returns JSON { "status": "CLEAN" | "INFECTED" }.
# Private manuscripts should only go to a scanner you control — do not point this
# at a third party without an explicit privacy decision.
MALWARE_SCANNER_PROVIDER=""
# Required when MALWARE_SCANNER_PROVIDER=clamav-http. The scan endpoint URL.
MALWARE_SCANNER_URL=""
# Optional bearer token sent to the scanner service (keep secret).
MALWARE_SCANNER_TOKEN=""
