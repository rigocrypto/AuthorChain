// AuthorChain data model (Phase 2).
// Money is stored as Decimal(12,2); the data-access layer converts to plain
// numbers/ISO strings before returning DTOs to the UI.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime queries use the pooled connection (Neon pooler / PgBouncer) so Vercel
  // serverless functions don't exhaust Postgres connections.
  url       = env("DATABASE_URL")
  // Migrations (`prisma migrate deploy/dev`) use a direct, non-pooled connection.
  // Locally DIRECT_URL can mirror DATABASE_URL (the local Postgres isn't pooled).
  directUrl = env("DIRECT_URL")
}

enum BookStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PaymentProvider {
  MOCK
  STRIPE
  USDC
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum RoyaltyStatus {
  PENDING
  PAID
}

enum AgentType {
  COPY
  LAUNCH
  COMMUNITY
}

enum RegistrationStatus {
  PENDING
  REGISTERED
  FAILED
}

enum StorageProvider {
  LOCAL
  S3
  IPFS
  ARWEAVE
  R2
}

enum AssetType {
  COVER
  BARCODE
  // Public reader-preview PDF (first pages only). Never the private manuscript.
  PREVIEW
  // Public back-cover image (wraparound print cover / storefront back).
  BACK_COVER
}

// Malware-scan state for an uploaded file/asset. Additive foundation (Security
// phase S1): UNKNOWN is the safe default for legacy/pre-scan rows. Serving/agent
// enforcement lands in later phases — do not block on this yet.
enum MalwareScanStatus {
  UNKNOWN
  PENDING
  CLEAN
  INFECTED
  ERROR
}

enum BookFormat {
  EBOOK
  PAPERBACK
  HARDCOVER
  AUDIOBOOK
}

enum AccessStatus {
  ACTIVE
  REFUNDED
  REVOKED
}

enum LicenseType {
  STANDARD
}

// Modern Bestsellers Agent — market research reports (author-private).
// Additive only. Status DRAFT = saved inputs/scaffold; READY = full report
// generated (Phase 2+); FAILED = generation error.
enum MarketResearchReportStatus {
  DRAFT
  READY
  FAILED
}

// --- Print edition settings (display/metadata only — no real print-on-demand) ---

enum PrintTrimSize {
  POCKET_4_25X6_87
  DIGEST_5_5X8_5
  US_TRADE_6X9
  ROYAL_6_14X9_21
  US_LETTER_8_5X11
  SQUARE_8_5X8_5
  CUSTOM
}

enum PrintInteriorColor {
  BLACK_AND_WHITE
  STANDARD_COLOR
  PREMIUM_COLOR
}

enum PrintPaperType {
  WHITE
  CREAM
  COLOR
}

enum PrintBinding {
  PERFECT_BOUND
  HARDCOVER_CASE_LAMINATE
  HARDCOVER_DUST_JACKET
  SADDLE_STITCH
  COIL_WIRE_O
}

enum PrintCoverFinish {
  MATTE
  GLOSSY
}

model Author {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  walletAddress String?
  avatarUrl     String?
  // Links this author to a Privy identity (account-abstraction auth). Set on
  // first authenticated login by matching the Privy-verified email.
  privyUserId   String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  books                   Book[]
  sales                   Sale[]
  royalties               Royalty[]
  agentOutputs            AgentOutput[]
  blockchainRegistrations BlockchainRegistration[]
  referralLinks           BookReferralLink[]
  printSettings           BookPrintSettings[]
  marketResearchReports   BookMarketResearchReport[]
}

model Book {
  id          String     @id @default(cuid())
  authorId    String
  title       String
  slug        String     @unique
  subtitle    String?
  description String
  category    String
  language    String     @default("English")
  price       Decimal    @db.Decimal(12, 2)
  currency    String     @default("USD")
  coverUrl    String?
  status      BookStatus @default(DRAFT)
  fileHash    String?
  // Soft-archive: hidden from the author's active dashboard list and from all
  // public pages while set. Restore = clear this. Never deletes files/proof/sales.
  archivedAt  DateTime?

  // Publishing identity (authors provide their own ISBN — we never issue one).
  isbn13          String?
  isbn10          String?
  publisherName   String?
  publicationDate DateTime?
  edition         String?
  bookFormat      BookFormat?

  // Extended catalog metadata + credits (all optional; public storefront display).
  pageCount          Int?
  readingTimeMinutes Int?
  audience           String?
  whatYouWillLearn   String?
  topics             String?
  acknowledgments    String?
  collaborators      String?
  contributors       String?
  editorName         String?
  coverDesignerName  String?
  illustratorName    String?
  translatorName     String?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  author                  Author                   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  files                   BookFile[]
  assets                  BookAsset[]
  sales                   Sale[]
  library                 ReaderLibrary[]
  reviews                 BookReview[]
  agentOutputs            AgentOutput[]
  blockchainRegistrations BlockchainRegistration[]
  referralLinks           BookReferralLink[]
  printSettings           BookPrintSettings?
  translations            BookTranslation[]
  marketResearchReports   BookMarketResearchReport[]

  @@index([authorId])
}

model BookTranslation {
  id          String   @id @default(cuid())
  bookId      String
  locale      String
  title       String
  subtitle    String?
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, locale])
  @@index([locale])
}

/**
 * Per-book print edition settings. Display/metadata only — AuthorChain does not
 * (yet) run real print-on-demand fulfillment. `isAvailable` gates whether the
 * print details appear on the public book page. One row per book.
 */
model BookPrintSettings {
  id       String  @id @default(cuid())
  bookId   String  @unique
  authorId String

  // Whether the print edition is shown as available on the public page.
  isAvailable Boolean @default(false)

  // Physical format.
  trimSize      PrintTrimSize      @default(US_TRADE_6X9)
  trimWidthIn   Float? // used when trimSize = CUSTOM (else derived from preset)
  trimHeightIn  Float?
  interiorColor PrintInteriorColor @default(BLACK_AND_WHITE)
  paperType     PrintPaperType     @default(WHITE)
  binding       PrintBinding       @default(PERFECT_BOUND)
  coverFinish   PrintCoverFinish   @default(MATTE)

  // Page count drives the derived spine width (persisted for display).
  pageCount    Int?
  spineWidthIn Float?

  // Print-edition identity + display-only pricing (separate from the ebook).
  printIsbn13 String?
  imprintName String?
  price       Decimal? @db.Decimal(12, 2)
  currency    String   @default("USD")

  // Optional display metadata.
  weightOz         Float?
  distributor      String?
  availabilityNote String?
  printNotes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  author Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
}

/** Shareable, tracked referral link for a book (analytics only — no payouts). */
model BookReferralLink {
  id            String   @id @default(cuid())
  bookId        String
  authorId      String
  code          String   @unique
  label         String?
  isActive      Boolean  @default(true)
  clickCount    Int      @default(0)
  checkoutCount Int      @default(0)
  saleCount     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  author Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@index([authorId])
}

model BookAsset {
  id              String          @id @default(cuid())
  bookId          String
  assetType       AssetType
  storageProvider StorageProvider @default(LOCAL)
  storageKey      String
  fileName        String
  mimeType        String
  fileSize        Int
  hash            String?
  isPrimary       Boolean         @default(true)
  // Malware-scan tracking (Security S1, additive). Legacy rows default UNKNOWN.
  scanStatus       MalwareScanStatus @default(UNKNOWN)
  scanProvider     String?
  scannedAt        DateTime?
  scanResult       Json?
  quarantineReason String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId, assetType])
}

model BookFile {
  id        String   @id @default(cuid())
  bookId    String
  fileName  String
  fileType  String
  // Protected storage locator (driver key). NOT a public URL. fileUrl stays
  // reserved for a future public/CDN URL and is null for protected local files.
  storageKey      String?
  storageProvider StorageProvider @default(LOCAL)
  fileUrl         String?
  fileSize        Int
  // sha-256 of the actual file bytes — used as the on-chain proof hash.
  hash      String?
  isPrimary Boolean  @default(true)
  // Malware-scan tracking (Security S1, additive). Legacy rows default UNKNOWN.
  scanStatus       MalwareScanStatus @default(UNKNOWN)
  scanProvider     String?
  scannedAt        DateTime?
  scanResult       Json?
  quarantineReason String?
  createdAt DateTime @default(now())

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
}

model Sale {
  id                    String          @id @default(cuid())
  bookId                String
  authorId              String
  buyerEmail            String?
  amount                Decimal         @db.Decimal(12, 2)
  currency              String          @default("USDC")
  paymentProvider       PaymentProvider @default(MOCK)
  paymentStatus         PaymentStatus   @default(PAID)
  stripeSessionId       String?         @unique
  stripePaymentIntentId String?
  createdAt             DateTime        @default(now())

  book      Book           @relation(fields: [bookId], references: [id], onDelete: Cascade)
  author    Author         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  royalties Royalty[]
  library   ReaderLibrary?

  @@index([bookId])
  @@index([authorId])
}

model Reader {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  walletAddress String?
  // Links this reader to a Privy identity; set on first login by matching email.
  privyUserId   String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  entitlements ReaderLibrary[]
  reviews      BookReview[]
}

model BookReview {
  id        String   @id @default(cuid())
  bookId    String
  readerId  String
  rating    Int
  thoughts  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  reader Reader @relation(fields: [readerId], references: [id], onDelete: Cascade)

  @@unique([bookId, readerId])
  @@index([bookId, createdAt])
  @@index([readerId])
}

model ReaderLibrary {
  id           String       @id @default(cuid())
  readerId     String
  bookId       String
  saleId       String       @unique
  accessStatus AccessStatus @default(ACTIVE)
  licenseType  LicenseType  @default(STANDARD)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  reader Reader @relation(fields: [readerId], references: [id], onDelete: Cascade)
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@unique([readerId, bookId])
  @@index([readerId])
  @@index([bookId])
}

model Royalty {
  id        String        @id @default(cuid())
  saleId    String
  authorId  String
  amount    Decimal       @db.Decimal(12, 2)
  currency  String        @default("USDC")
  status    RoyaltyStatus @default(PENDING)
  createdAt DateTime      @default(now())

  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)
  author Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
}

model AgentOutput {
  id        String    @id @default(cuid())
  bookId    String
  authorId  String
  agentType AgentType
  input     String
  output    String
  createdAt DateTime  @default(now())

  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  author Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([bookId])
}

model BlockchainRegistration {
  id              String             @id @default(cuid())
  bookId          String
  authorId        String
  chain           String
  contractAddress String?
  transactionHash String?
  bookHash        String
  status          RegistrationStatus @default(PENDING)
  createdAt       DateTime           @default(now())

  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  author Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([bookId])
}

/**
 * Modern Bestsellers Agent — author-private market intelligence reports.
 * MVP stores structured summaries + user source URL references only.
 * Does not store bulk copyrighted review text or marketplace credentials.
 * Optional bookId: standalone research before a book exists is allowed.
 */
model BookMarketResearchReport {
  id                  String                      @id @default(cuid())
  authorId            String
  bookId              String?
  genre               String
  sourceUrls          Json?
  inputSummary        String?
  trendSignals        Json?
  reviewPatterns      Json?
  opportunityGaps     Json?
  recommendedConcepts Json?
  warnings            Json?
  report              Json?
  status              MarketResearchReportStatus  @default(DRAFT)
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt

  author Author @relation(fields: [authorId], references: [id], onDelete: Cascade)
  book   Book?  @relation(fields: [bookId], references: [id], onDelete: SetNull)

  @@index([authorId, createdAt])
  @@index([authorId, bookId])
}
