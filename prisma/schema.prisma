// AuthorChain data model (Phase 2).
// Money is stored as Decimal(12,2); the data-access layer converts to plain
// numbers/ISO strings before returning DTOs to the UI.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime queries use the pooled connection (Neon pooler / PgBouncer) so Vercel
  // serverless functions don't exhaust Postgres connections.
  url       = env("DATABASE_URL")
  // Migrations (`prisma migrate deploy/dev`) use a direct, non-pooled connection.
  // Locally DIRECT_URL can mirror DATABASE_URL (the local Postgres isn't pooled).
  directUrl = env("DIRECT_URL")
}

enum BookStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PaymentProvider {
  MOCK
  STRIPE
  USDC
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum RoyaltyStatus {
  PENDING
  PAID
}

enum AgentType {
  COPY
  LAUNCH
  COMMUNITY
}

enum RegistrationStatus {
  PENDING
  REGISTERED
  FAILED
}

enum StorageProvider {
  LOCAL
  S3
  IPFS
  ARWEAVE
  R2
}

enum AssetType {
  COVER
  BARCODE
  // Public reader-preview PDF (first pages only). Never the private manuscript.
  PREVIEW
  // Public back-cover image (wraparound print cover / storefront back).
  BACK_COVER
}

enum BookFormat {
  EBOOK
  PAPERBACK
  HARDCOVER
  AUDIOBOOK
}

enum AccessStatus {
  ACTIVE
  REFUNDED
  REVOKED
}

enum LicenseType {
  STANDARD
}

model Author {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  walletAddress String?
  avatarUrl     String?
  // Links this author to a Privy identity (account-abstraction auth). Set on
  // first authenticated login by matching the Privy-verified email.
  privyUserId   String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  books                   Book[]
  sales                   Sale[]
  royalties               Royalty[]
  agentOutputs            AgentOutput[]
  blockchainRegistrations BlockchainRegistration[]
  referralLinks           BookReferralLink[]
}

model Book {
  id          String     @id @default(cuid())
  authorId    String
  title       String
  slug        String     @unique
  subtitle    String?
  description String
  category    String
  language    String     @default("English")
  price       Decimal    @db.Decimal(12, 2)
  currency    String     @default("USD")
  coverUrl    String?
  status      BookStatus @default(DRAFT)
  fileHash    String?
  // Soft-archive: hidden from the author's active dashboard list and from all
  // public pages while set. Restore = clear this. Never deletes files/proof/sales.
  archivedAt  DateTime?

  // Publishing identity (authors provide their own ISBN — we never issue one).
  isbn13          String?
  isbn10          String?
  publisherName   String?
  publicationDate DateTime?
  edition         String?
  bookFormat      BookFormat?

  // Extended catalog metadata + credits (all optional; public storefront display).
  pageCount          Int?
  readingTimeMinutes Int?
  audience           String?
  whatYouWillLearn   String?
  topics             String?
  acknowledgments    String?
  collaborators      String?
  contributors       String?
  editorName         String?
  coverDesignerName  String?
  illustratorName    String?
  translatorName     String?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  author                  Author                   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  files                   BookFile[]
  assets                  BookAsset[]
  sales                   Sale[]
  library                 ReaderLibrary[]
  agentOutputs            AgentOutput[]
  blockchainRegistrations BlockchainRegistration[]
  referralLinks           BookReferralLink[]

  @@index([authorId])
}

/** Shareable, tracked referral link for a book (analytics only — no payouts). */
model BookReferralLink {
  id            String   @id @default(cuid())
  bookId        String
  authorId      String
  code          String   @unique
  label         String?
  isActive      Boolean  @default(true)
  clickCount    Int      @default(0)
  checkoutCount Int      @default(0)
  saleCount     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  author Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@index([authorId])
}

model BookAsset {
  id              String          @id @default(cuid())
  bookId          String
  assetType       AssetType
  storageProvider StorageProvider @default(LOCAL)
  storageKey      String
  fileName        String
  mimeType        String
  fileSize        Int
  hash            String?
  isPrimary       Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId, assetType])
}

model BookFile {
  id        String   @id @default(cuid())
  bookId    String
  fileName  String
  fileType  String
  // Protected storage locator (driver key). NOT a public URL. fileUrl stays
  // reserved for a future public/CDN URL and is null for protected local files.
  storageKey      String?
  storageProvider StorageProvider @default(LOCAL)
  fileUrl         String?
  fileSize        Int
  // sha-256 of the actual file bytes — used as the on-chain proof hash.
  hash      String?
  isPrimary Boolean  @default(true)
  createdAt DateTime @default(now())

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
}

model Sale {
  id                    String          @id @default(cuid())
  bookId                String
  authorId              String
  buyerEmail            String?
  amount                Decimal         @db.Decimal(12, 2)
  currency              String          @default("USDC")
  paymentProvider       PaymentProvider @default(MOCK)
  paymentStatus         PaymentStatus   @default(PAID)
  stripeSessionId       String?         @unique
  stripePaymentIntentId String?
  createdAt             DateTime        @default(now())

  book      Book           @relation(fields: [bookId], references: [id], onDelete: Cascade)
  author    Author         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  royalties Royalty[]
  library   ReaderLibrary?

  @@index([bookId])
  @@index([authorId])
}

model Reader {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  walletAddress String?
  // Links this reader to a Privy identity; set on first login by matching email.
  privyUserId   String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  entitlements ReaderLibrary[]
}

model ReaderLibrary {
  id           String       @id @default(cuid())
  readerId     String
  bookId       String
  saleId       String       @unique
  accessStatus AccessStatus @default(ACTIVE)
  licenseType  LicenseType  @default(STANDARD)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  reader Reader @relation(fields: [readerId], references: [id], onDelete: Cascade)
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@unique([readerId, bookId])
  @@index([readerId])
  @@index([bookId])
}

model Royalty {
  id        String        @id @default(cuid())
  saleId    String
  authorId  String
  amount    Decimal       @db.Decimal(12, 2)
  currency  String        @default("USDC")
  status    RoyaltyStatus @default(PENDING)
  createdAt DateTime      @default(now())

  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)
  author Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
}

model AgentOutput {
  id        String    @id @default(cuid())
  bookId    String
  authorId  String
  agentType AgentType
  input     String
  output    String
  createdAt DateTime  @default(now())

  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  author Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([bookId])
}

model BlockchainRegistration {
  id              String             @id @default(cuid())
  bookId          String
  authorId        String
  chain           String
  contractAddress String?
  transactionHash String?
  bookHash        String
  status          RegistrationStatus @default(PENDING)
  createdAt       DateTime           @default(now())

  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  author Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([bookId])
}
